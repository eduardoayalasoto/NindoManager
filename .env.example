# ============================================================
# NINDO MANAGER — Variables de entorno
# Copia este archivo como .env y ajusta los valores.
# ============================================================

# Django
DEBUG=True
SECRET_KEY=cambia-esto-en-produccion-usa-una-clave-larga-y-random
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# Base de datos
# Desarrollo: SQLite (por defecto, no necesitas configurar nada)
# Producción con SQLite en Railway: sqlite:////mnt/data/db.sqlite3
# Producción con PostgreSQL: postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///db.sqlite3

# Redis y Celery (opcional en desarrollo — si no está, Celery corre en modo sync)
# REDIS_URL=redis://localhost:6379/0

# ============================================================
# WhatsApp
# WHATSAPP_PROVIDER controla qué proveedor se usa:
#   console  → imprime en terminal (desarrollo, sin cuenta requerida)
#   meta     → Meta Cloud API (requiere cuenta Meta Business)
#   twilio   → Twilio WhatsApp (requiere cuenta Twilio)
# ============================================================
WHATSAPP_PROVIDER=console

# Meta Cloud API (si WHATSAPP_PROVIDER=meta)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Twilio (si WHATSAPP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886

# ============================================================
# Email
# En desarrollo usa console (imprime en terminal).
# En producción configura SendGrid o SMTP.
# ============================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@nindocombat.com

# SendGrid (producción)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxx
# EMAIL_BACKEND=anymail.backends.sendgrid.EmailBackend
